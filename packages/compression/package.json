{
    "name": "compression",
    "version": "1.0.0",
    "author": "Kensa",
    "private": true,
    "scripts": {
        "build": "wasm-pack build --target nodejs --out-dir pkg/pkg-node && wasm-pack build --target bundler --out-dir pkg/pkg-browser",
        "cargo": "cargo"
    },
    "devDependencies": {
        "wasm-pack": "^0.14.0"
    },
    "exports": {
        ".": {
            "browser": {
                "types": "./pkg/pkg-browser/compression.d.ts",
                "default": "./pkg/pkg-browser/compression.js"
            },
            "default": {
                "types": "./pkg/pkg-node/compression.d.ts",
                "default": "./pkg/pkg-node/compression.js"
            }
        }
    }
}
