{
    "$schema": "https://turbo.build/schema.json",
    "globalPassThroughEnv": [],
    "tasks": {
        "release": {
            "dependsOn": ["^build"],
            "cache": false
        },
        "dev": {
            "dependsOn": ["^build", "build"],
            "cache": false,
            "persistent": true
        },
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["src/**/*"],
            "outputs": ["dist/**/*", "index.node"],
            "outputLogs": "new-only"
        }
    }
}
